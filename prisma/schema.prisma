datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// --------------------------------------
// AUTHENTICATION (NEXTAUTH MASTER TABLES)
// --------------------------------------

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  
  // ✨ Added for Email/Password Login
  hashedPassword String?   
  
  // ✨ Tells us what kind of dashboard to load
  role           Role      @default(STUDENT) 
  createdAt      DateTime  @default(now())

  accounts       Account[]
  sessions       Session[]

  // ✨ Links to their specific profile
  tutorProfile   Tutor?
  studentProfile Student?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  STUDENT
  TUTOR
}

// --------------------------------------
// PROFILES (TUTOR & STUDENT)
// --------------------------------------

model Tutor {
  id              String         @id @default(cuid())
  
  // ✨ Connected to the Master User
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  username        String         @unique
  name            String
  email           String         @unique
  bio             String?        @db.Text
  profileImage    String?        
  defaultDuration Int            @default(60) 
  pricePerHour    Int            @default(100)
  createdAt       DateTime       @default(now())

  // location attributes:
  address           String?
  city              String?
  country           String?
  latitude          Float?    // The exact North/South coordinate
  longitude         Float?    // The exact East/West coordinate
  maxTravelDistance Int       @default(10)


  teachingModes  TeachingMode[] // Array of modes they offer
  isVerified     Boolean        @default(false) // For the blue checkmark!
  
  
  // Relations
  subjects        Subject[]
  availability    Availability[]
  bookings        Booking[]
  education       Education[]
  experience      Experience[]
  reviews        Review[]       // Connection to the new review system

}

model Student {
  id        String    @id @default(cuid())
  
  // ✨ Connected to the Master User
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ✨ UPGRADED LOCATION DATA
  address           String?
  city              String?
  country           String?
  latitude          Float?
  longitude         Float?

  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  
  // Relations
  bookings  Booking[]
  reviews   Review[]
}

// --------------------------------------
// SCHEDULING & BOOKINGS
// --------------------------------------

model Booking {
  id        String   @id @default(cuid())
  day       String   // e.g., "MONDAY"
  timeSlot  String   // e.g., "09:00 - 10:00"
  
  // ✨ NEW CALENDAR & RECURRING FEATURES
  date             DateTime? // The exact calendar date (e.g., Oct 24, 2026)
  isRecurring      Boolean   @default(false) 
  recurringGroupId String?   // Links all lessons in a weekly series together
  
  // ✨ NEW POST-LESSON FEATURES
  tutorNotes       String?   @db.Text // Homework, feedback, or summary

  status    String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  createdAt DateTime @default(now())

  tutorId   String
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  mode      TeachingMode @default(ONLINE)
  review    Review?      // A booking can have ONE review attached to it
}

model Availability {
  id        String    @id @default(cuid())
  day       DayOfWeek
  startTime String    // e.g., "09:00"
  endTime   String    // e.g., "17:00"
  
  tutorId   String
  tutor     Tutor     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// --------------------------------------
// METADATA
// --------------------------------------

model Subject {
  id     String  @id @default(cuid())
  name   String  @unique
  tutors Tutor[]
}

model Education {
  id          String   @id @default(cuid())
  degree      String   
  institution String   
  startYear   Int
  endYear     Int?     
  
  tutorId     String
  tutor       Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  documentUrl String?   // Secure URL to the uploaded diploma/transcript
  isVerified  Boolean   @default(false)
}

model Experience {
  id          String   @id @default(cuid())
  title       String   
  company     String   
  startYear   Int
  endYear     Int?     
  description String?  
  
  tutorId     String
  tutor       Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

enum TeachingMode {
  ONLINE
  IN_PERSON_TUTOR  // At the tutor's house/office
  IN_PERSON_STUDENT // At the student's house
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED // ✨ NEW: We need this so students can only review finished lessons!
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1 to 5 stars
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  bookingId   String   @unique // One review per booking
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  tutorId     String
  tutor       Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}